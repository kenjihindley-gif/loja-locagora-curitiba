{
  "hosting": {
    "site": "loja-locagora",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "run": {
          "serviceId": "loja-locagora-curitiba",
          "region": "us-east4"
        }
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
