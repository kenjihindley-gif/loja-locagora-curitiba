rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /motorcycles/{motorcycleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /sellers/{sellerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
